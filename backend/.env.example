# Required in production. In local dev with the Firebase emulator, leave empty.
GOOGLE_APPLICATION_CREDENTIALS=

FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# CORS origins (comma-separated). Use the Firebase Hosting URL in prod.
CORS_ALLOW_ORIGINS=http://localhost:5173

# Where compiled PDFs are cached on disk inside the container.
COMPILE_WORKDIR=/tmp/latex-hub
